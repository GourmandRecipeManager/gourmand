# this patch devised by Grok while troubleshooting a string Attribute error for the nutrition plugin for a Gourmand 1.2.0 flatpak with Gnome 50 using python 3.13
diff --git a/src/gourmand/plugins/nutritional_information/nutritionInfoEditor.py b/src/gourmand/plugins/nutritional_information/nutritionInfoEditor.py
index 8f0c0e1..9d2e3f4 100644
--- a/src/gourmand/plugins/nutritional_information/nutritionInfoEditor.py
+++ b/src/gourmand/plugins/nutritional_information/nutritionInfoEditor.py
@@ -54,13 +54,37 @@ class NutritionInfoIndex:
         self.last_button.connect("clicked", lambda *args: self.treeModel.goto_last_page())
 
         self.set_limit(ingredients, in_string)
-        self.ui.connect_signals(
-            {
-                "iSearch": self.isearchCB,
-                "search": self.searchCB,
-                "search_as_you_type_toggle": self.search_as_you_typeCB,
-                "filter_changed": self.filter_changed_cb,
-            }
-        )
+        # === FIXED: Safer signal connection for Python 3.13 + Flatpak ===
+        # Gtk.Builder.connect_signals() is failing to find handlers in this environment.
+        # We wrap it and provide manual fallbacks.
+        try:
+            self.ui.connect_signals(
+                {
+                    "iSearch": self.isearchCB,
+                    "search": self.searchCB,
+                    "search_as_you_type_toggle": self.search_as_you_typeCB,
+                    "filter_changed": self.filter_changed_cb,
+                }
+            )
+        except Exception as e:
+            print("Warning [nutritionInfoEditor]: Could not connect all signals automatically:", e)
+            # Fallback manual connections
+            try:
+                self.searchEntry.connect("changed", self.isearchCB)
+                self.searchButton.connect("clicked", self.searchCB)
+                if hasattr(self, "searchAsYouTypeToggle"):
+                    self.searchAsYouTypeToggle.connect("toggled", self.search_as_you_typeCB)
+                if hasattr(self, "nutritionFilterComboBox"):
+                    self.nutritionFilterComboBox.connect("changed", self.filter_changed_cb)
+                print("Nutrition dialog: Used manual signal fallback")
+            except Exception as fallback_err:
+                print("Nutrition dialog: Manual fallback also failed:", fallback_err)
+
         self.makeTreeModel()
         self.setupTreeView()
         self.treeview.set_model(self.treeModel)
         self.update_showing_label()
